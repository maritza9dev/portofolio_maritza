// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  moduleFormat = "esm"
  generatedFileExtension = "ts"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model biodata {
  id                Int      @id @default(autoincrement())
  short_description String
  long_description  String   @db.Text
  position          String
  image             String
  document          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime? @updatedAt
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

enum SkillCategory {
  SoftSkills
  HardSkills
  Tools
}

model Skill {
  id        Int           @id @default(autoincrement())
  name      String
  category  SkillCategory
  level     Level
  createdAt DateTime      @default(now())
  updatedAt DateTime?     @updatedAt
}

model Project {
  id           Int      @id @default(autoincrement())
  name_p       String
  description  String?   @db.Text
  role         String
  tech         String[]
  image        String
  link_github  String?
  projectDate  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt
}

model Education {
  id          Int      @id @default(autoincrement())
  school_name String
  degree      String
  major       String?
  year_start  Int
  year_end    Int?
  is_current  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt
}

enum ExperienceType {
  FullTime
  Internship
  Training
}

model Experience {
  id          Int            @id @default(autoincrement())
  type        ExperienceType
  title       String         
  institution String         
  description String?         @db.Text
  year_start  Int
  year_end    Int?
  is_current  Boolean        @default(false)
  certificate String?        
  createdAt   DateTime       @default(now())
  updatedAt   DateTime?      @updatedAt
}

model Activity {
  id          Int          @id @default(autoincrement())
  type        String
  title       String       
  position    String       
  description String?      @db.Text
  year_start  Int
  year_end    Int?
  image       String?
  is_current  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @updatedAt
}

model Contact {
  id        Int           @id @default(autoincrement())
  icon      String
  apk       String
  link      String
  decs      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime?     @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}